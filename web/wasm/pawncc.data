	NPC_MOVE_TYPE_NONE                         = 0,
	NPC_MOVE_TYPE_WALK,
	NPC_MOVE_TYPE_JOG,
	NPC_MOVE_TYPE_SPRINT,
	NPC_MOVE_TYPE_DRIVE,
	NPC_MOVE_TYPE_AUTO
}

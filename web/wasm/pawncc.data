 * <returns>
 *   <b><c>occupant's ID</c></b>: There is a player in that seat.<br />
 *   <b><c>INVALID_PLAYER_ID</c></b>: The seat is empty or the vehicle is not created.
 * </returns>
 */
native GetVehicleOccupant(vehicleid, seatid);

